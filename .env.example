# KathiCredentials — Environment Variables
# Copy this to .env and fill in values

# Neo4j (reuse existing experience-neo4j container)
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=experience123

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-44-char-fernet-key-here

# Admin token (generate any secure random string, e.g. from 1password or openssl)
ADMIN_TOKEN=change-this-to-a-secure-random-token

# API Server
API_PORT=8124
LOG_LEVEL=INFO

# Telegram (fill in after creating bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=